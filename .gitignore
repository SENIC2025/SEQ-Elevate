# dependencies
/node_modules
node_modules/
/.pnp
.pnp.*

# nested apps (Strapi build artifacts)
/cms/.tmp
/cms/.cache
/cms/.strapi
/cms/dist
/cms/build
/cms/.env
/cms/exports
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

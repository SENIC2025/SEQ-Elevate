{
  "kind": "collectionType",
  "collectionName": "courses",
  "info": {
    "singularName": "course",
    "pluralName": "courses",
    "displayName": "Course",
    "description": "A micro-course. The WP3 7-stage pedagogical sequence is enforced by the platform; this holds the authored content."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "cluster": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "clusterLabel": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "tagline": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "durationMinutes": {
      "type": "integer",
      "default": 20,
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "badgeName": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "badgeMeaning": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "badgeSlug": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "completionTitle": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "completionBody": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "content": {
      "type": "json",
      "pluginOptions": { "i18n": { "localized": true } }
    }
  }
}
